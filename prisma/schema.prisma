// 占いクラウド リニューアル — Prisma Schema（Phase 2 草案）
// 技術: PostgreSQL / Prisma。CC-Auth 連携・3ロール RBAC・占い師カタログ・予約・ブログ。
// 注記: この段階では migration は実行しない（schema 構文確定のみ）。
//        domain / cc_auth は .ccagi.yml 未設定（OPEN-1/OPEN-2）。

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  // Vercel/Neon serverless: DATABASE_URL は接続プール (PgBouncer 経由) 用、
  // DIRECT_URL は migration / introspection 用の直結。ローカル(:5433)は
  // プール不要のため両者を同値にしてよい（.env 参照）。
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  // ADR-2: 日本語検索は pg_trgm（bigram + GIN）。拡張を宣言的に有効化し migration に含める。
  // GIN index 本体は後続 Wave で追加（schema 本文を汚さない方針）。
  extensions = [pg_trgm]
}

// ===========================================================================
// Enums
// ===========================================================================

enum UserRole {
  GENERAL // 一般ユーザー（Seeker）
  FORTUNE_TELLER // 占い師（Advisor）
  ADMIN // 運営管理者
}

enum ConsultationMethod {
  PHONE // 電話
  CHAT // チャット
  EMAIL // メール
  ZOOM // Zoom
  IN_PERSON // 対面
}

enum ConsultationStatus {
  PENDING // 受付（初期）
  ACCEPTED // 占い師承認（MVPゴール）
  RESCHEDULED // 日程調整提案
  DECLINED // 占い師辞退
  CANCELLED // ユーザー取消
}

enum PostStatus {
  DRAFT // 下書き
  SCHEDULED // 予約投稿
  PUBLISHED // 公開
  ARCHIVED // 非公開（取下げ/運営 archive）
}

enum DivinationCategorySlug {
  TAROT // タロット
  PALMISTRY // 手相
  FOUR_PILLARS // 四柱推命
  NINE_STAR_KI // 九星気学
  NUMEROLOGY // 数秘
  SPIRITUAL_SENSE // 霊感
  FENG_SHUI // 風水
  PHYSIOGNOMY // 人相
  WESTERN_ASTROLOGY // 西洋占星術
  SPIRITUAL // スピリチュアル
  SANMEI // 算命
  EKI // 易
  NAME_DIVINATION // 姓名判断
  SIX_STAR // 六星
  OTHER // その他
}

// ===========================================================================
// User & Auth（CC-Auth 連携）
// ===========================================================================

model User {
  id          String   @id @default(cuid())
  // CC-Auth subject（userPoolId 配下の sub）。突合方針は OPEN-4。
  ccAuthSub   String?  @unique
  email       String   @unique
  displayName String
  role        UserRole @default(GENERAL)
  avatarUrl   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  fortuneTellerProfile FortuneTellerProfile?
  consultationRequests ConsultationRequest[] @relation("RequesterRequests")
  favorites            Favorite[]
  reviews              Review[]              @relation("ReviewAuthor")
  authoredPosts        BlogPost[]            @relation("AuthoredPosts") // 著者=User（占い師 or 運営）
  notifications        Notification[]

  @@index([role])
  @@index([ccAuthSub])
}

// ===========================================================================
// 占い師カタログ
// ===========================================================================

model FortuneTellerProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  slug          String   @unique // SEO 可読 URL: /advisors/[slug]
  bio           String   @db.Text // 自己紹介・経歴
  experience    String?  @db.Text // 活動実績
  photoUrl      String?
  isPublished   Boolean  @default(false)
  // 集計用キャッシュ（StatBand / 並び替え）。実値は集計で更新。
  ratingAverage Float? // null=評価データなし
  ratingCount   Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories           AdvisorCategory[]
  methods              AdvisorMethod[]
  services             Service[]
  consultationRequests ConsultationRequest[] @relation("AdvisorRequests")
  blogPosts            BlogPost[]            @relation("AdvisorPosts") // 占い師著者の記事（カタログ統合 C-4）
  reviews              Review[]              @relation("ReviewTarget")
  favoritedBy          Favorite[]

  @@index([isPublished])
  @@index([ratingAverage])
}

model DivinationCategory {
  id          String                 @id @default(cuid())
  slug        DivinationCategorySlug @unique
  name        String // 表示名（日本語）
  description String?
  iconKey     String? // lucide / カスタムSVG キー
  sortOrder   Int                    @default(0)

  advisors AdvisorCategory[]
  services Service[]

  @@index([sortOrder])
}

// 占い師 × 占術カテゴリ（中間テーブル, 多対多 + 主占術フラグ）
model AdvisorCategory {
  advisorId  String
  categoryId String
  isPrimary  Boolean @default(false)

  advisor  FortuneTellerProfile @relation(fields: [advisorId], references: [id], onDelete: Cascade)
  category DivinationCategory   @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([advisorId, categoryId])
  @@index([categoryId])
}

// 占い師 × 相談形式（中間テーブル）
model AdvisorMethod {
  advisorId String
  method    ConsultationMethod

  advisor FortuneTellerProfile @relation(fields: [advisorId], references: [id], onDelete: Cascade)

  @@id([advisorId, method])
  @@index([method])
}

model Service {
  id          String             @id @default(cuid())
  advisorId   String
  categoryId  String
  title       String
  description String             @db.Text
  method      ConsultationMethod
  priceJpy    Int // 価格（保持・表示のみ。決済は次フェーズ）
  durationMin Int // 所要時間（分）
  isPublished Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  advisor              FortuneTellerProfile  @relation(fields: [advisorId], references: [id], onDelete: Cascade)
  category             DivinationCategory    @relation(fields: [categoryId], references: [id])
  consultationRequests ConsultationRequest[]

  @@index([advisorId])
  @@index([categoryId])
  @@index([isPublished])
  @@index([priceJpy])
}

// ===========================================================================
// 予約リクエスト（状態遷移）
// ===========================================================================

model ConsultationRequest {
  id          String             @id @default(cuid())
  requesterId String // 一般ユーザー
  advisorId   String // 対象占い師
  serviceId   String? // サービス指定時（占い師のみ指定も可）
  method      ConsultationMethod
  summary     String             @db.Text // 相談概要（サニタイズ済保存。要配慮個人情報 — privacy §参照）
  status      ConsultationStatus @default(PENDING)
  responseMessage String?        @db.Text // 占い師の応答メッセージ（承認/辞退理由/日程提案コメント）
  proposedSlot    DateTime?      // RESCHEDULED 時に占い師が提案する日時
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  respondedAt DateTime?

  requester      User                        @relation("RequesterRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  advisor        FortuneTellerProfile        @relation("AdvisorRequests", fields: [advisorId], references: [id], onDelete: Cascade)
  service        Service?                    @relation(fields: [serviceId], references: [id])
  preferredSlots ConsultationPreferredSlot[]

  @@index([requesterId])
  @@index([advisorId])
  @@index([status])
}

// 希望日時候補（1リクエストに複数, 最大3 はアプリ層で検証）
model ConsultationPreferredSlot {
  id        String   @id @default(cuid())
  requestId String
  slot      DateTime
  sortOrder Int      @default(0)

  request ConsultationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
}

// お気に入り（一般ユーザー → 占い師）
model Favorite {
  userId    String
  advisorId String
  createdAt DateTime @default(now())

  user    User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  advisor FortuneTellerProfile @relation(fields: [advisorId], references: [id], onDelete: Cascade)

  @@id([userId, advisorId])
  @@index([advisorId])
}

// 口コミ・評価（既存データ移行 / 新規投稿は次フェーズ NF-7）
model Review {
  id               String   @id @default(cuid())
  authorId         String? // 新規投稿時の User。移行レビューで評価者が User 未移行なら null（NF-7 まで表示専用）
  legacyAuthorName String? // 移行元の評価者表示名（authorId が null の移行レビュー用）
  advisorId        String
  rating           Int // 1-5（アプリ層で範囲検証）
  comment          String?  @db.Text
  createdAt        DateTime @default(now())

  author  User?                @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  advisor FortuneTellerProfile @relation("ReviewTarget", fields: [advisorId], references: [id], onDelete: Cascade)

  @@index([advisorId])
  @@index([rating])
}

// ===========================================================================
// ブログ（本体統合・占い師＝著者）
// ===========================================================================

model BlogPost {
  id               String  @id @default(cuid())
  authorId         String // 著者 User（FORTUNE_TELLER または ADMIN/運営）
  advisorProfileId String? // 占い師著者のプロフィール紐付け（カタログ統合 C-4）。運営投稿は null
  categoryId       String
  slug         String     @unique // 公開後不変（SEO-16）
  title        String
  excerpt      String?    @db.Text
  contentJson  Json // Tiptap JSON
  contentHtml  String     @db.Text // サニタイズ済 HTML
  thumbnailUrl String?
  status       PostStatus @default(DRAFT)
  publishedAt  DateTime? // SCHEDULED 時は未来。PUBLISHED 確定時刻
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // SEO 上書き（任意, AC-C2-8）
  seoTitle       String?
  seoDescription String?
  ogImageUrl     String?

  author         User                  @relation("AuthoredPosts", fields: [authorId], references: [id], onDelete: Cascade)
  advisorProfile FortuneTellerProfile? @relation("AdvisorPosts", fields: [advisorProfileId], references: [id])
  category       BlogCategory          @relation(fields: [categoryId], references: [id])
  tags           BlogPostTag[]

  @@index([status, publishedAt])
  @@index([authorId])
  @@index([advisorProfileId])
  @@index([categoryId])
}

model BlogCategory {
  id          String  @id @default(cuid())
  slug        String  @unique // /blog/category/[slug]
  name        String
  description String?
  sortOrder   Int     @default(0)

  posts BlogPost[]

  @@index([sortOrder])
}

model BlogTag {
  id   String @id @default(cuid())
  slug String @unique // /blog/tag/[slug]
  name String

  posts BlogPostTag[]
}

// 記事 × タグ（中間テーブル, 多対多）
model BlogPostTag {
  postId String
  tagId  String

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
}

// ===========================================================================
// 通知（AC-B7-6: 最低限アプリ内通知）
// ===========================================================================

enum NotificationType {
  CONSULTATION_STATUS // 予約リクエスト状態変化（pending→accepted 等）
  POST_PUBLISHED // 予約投稿の公開完了
  SYSTEM // 運営からのお知らせ
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?          @db.Text
  linkUrl   String? // 通知タップ時の遷移先（リクエスト詳細・記事等）
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}
